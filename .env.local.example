# LinkedIn auto-posting — copy to .env.local and fill in.
# .env.local is git-ignored; never commit real tokens.

# From your LinkedIn app's Auth tab (https://www.linkedin.com/developers/apps):
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Printed by `npm run linkedin:token` — paste the values it gives you:
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# Optional: only present if your app is granted programmatic refresh.
# LINKEDIN_REFRESH_TOKEN=

# Optional: override the monthly LinkedIn API version (YYYYMM) if you hit a
# version error. Defaults to a recent version in the script.
# LINKEDIN_API_VERSION=202506
